pipeline {
    agent any

    environment {
        // NCP Container Registry (NCR)
        NCR_REGISTRY = credentials('ncr-registry')   // 예: xxxxx.kr.ncr.ntruss.com
        IMAGE_NAME   = 'db-migration'
        IMAGE_TAG    = "${BUILD_NUMBER}"
        NCR_CRED     = credentials('ncr-credentials') // NCP API Key (Access Key / Secret Key)
    }

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: '배포 환경 선택')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Migration App') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh '../../gradlew bootJar'
                }
            }
        }

        stage('Build & Push Docker Image') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh """
                        # NCP Container Registry 로그인
                        docker login ${NCR_REGISTRY} -u ${NCR_CRED_USR} -p ${NCR_CRED_PSW}

                        # 이미지 빌드 & 푸시
                        docker build -t ${NCR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} .
                        docker push ${NCR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Apply NCP DB Service') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh '''
                        # NCP DB ExternalName 서비스 등록
                        kubectl apply -f k8s/ncp-db-service.yml
                    '''
                }
            }
        }

        stage('Run K8s Migration Job') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh """
                        # Secret 적용 (NCP DB 접속 정보)
                        kubectl apply -f k8s/db-secret.yml

                        # 기존 Job이 있으면 삭제
                        kubectl delete job db-migration-job --ignore-not-found=true

                        # 이미지 태그를 NCR 이미지로 교체하여 Job 실행
                        sed "s|brunosong/db-migration:latest|${NCR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}|g" \
                            k8s/migration-job.yml | kubectl apply -f -

                        # Job 완료 대기 (최대 5분)
                        kubectl wait --for=condition=complete job/db-migration-job --timeout=300s
                    """
                }
            }
        }

        stage('Verify Migration') {
            steps {
                sh 'kubectl logs job/db-migration-job'
            }
        }
    }

    post {
        success {
            echo 'NCP Cloud DB 마이그레이션 성공!'
        }
        failure {
            echo 'DB 마이그레이션 실패. K8s Job 로그를 확인하세요.'
            sh 'kubectl logs job/db-migration-job || true'
        }
    }
}
