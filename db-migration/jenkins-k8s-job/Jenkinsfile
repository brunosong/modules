pipeline {
    agent any

    environment {
        IMAGE_NAME   = 'db-migration'
        IMAGE_TAG    = "${BUILD_NUMBER}"
        KIND_CLUSTER = 'db-migration'
    }

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: '배포 환경 선택')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Migration App') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    // Windows에서 체크아웃된 파일은 실행 권한이 없을 수 있어 chmod 후 실행
                    sh 'chmod +x ../../gradlew && ../../gradlew :db-migration:jenkins-k8s-job:bootJar'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Load Image to Kind') {
            steps {
                // kind load 대신 docker save 출력을 바로 ctr import로 파이프
                // 중간 파일 없이 stdin으로 전달해서 경로/권한 문제 회피
                sh """
                    docker save ${IMAGE_NAME}:${IMAGE_TAG} | \
                        docker exec -i ${KIND_CLUSTER}-control-plane ctr -n k8s.io images import -
                """
            }
        }

        stage('Apply External DB Service') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh 'kubectl apply -f k8s/ncp-db-service.yml'
                }
            }
        }

        stage('Run K8s Migration Job') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh """
                        # DB 접속 정보 Secret 적용
                        kubectl apply -f k8s/db-secret.yml

                        # 기존 Job 삭제
                        kubectl delete job db-migration-job --ignore-not-found=true

                        # 이미지 태그 교체하여 Job 실행
                        sed "s|brunosong/db-migration:latest|${IMAGE_NAME}:${IMAGE_TAG}|g" \
                            k8s/migration-job.yml | kubectl apply -f -

                        # Job 완료 대기 (최대 5분)
                        kubectl wait --for=condition=complete job/db-migration-job --timeout=300s
                    """
                }
            }
        }

        stage('Verify Migration') {
            steps {
                sh 'kubectl logs job/db-migration-job'
            }
        }
    }

    post {
        success {
            echo 'DB 마이그레이션 성공!'
        }
        failure {
            echo 'DB 마이그레이션 실패. 위 stage 로그를 확인하세요.'
            sh '''
                if kubectl get job db-migration-job >/dev/null 2>&1; then
                    kubectl logs job/db-migration-job
                else
                    echo "(Job이 아직 생성되지 않음 - 이전 stage에서 실패)"
                fi
            '''
        }
    }
}
