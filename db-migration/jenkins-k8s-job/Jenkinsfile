pipeline {
    agent any

    environment {
        IMAGE_NAME   = 'db-migration'
        IMAGE_TAG    = "${BUILD_NUMBER}"
        KIND_CLUSTER = 'db-migration'
    }

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: '배포 환경 선택')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Migration App') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh '../../gradlew bootJar'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Load Image to Kind') {
            steps {
                // 레지스트리 push 없이 Kind 클러스터에 이미지 직접 로드
                sh "kind load docker-image ${IMAGE_NAME}:${IMAGE_TAG} --name ${KIND_CLUSTER}"
            }
        }

        stage('Apply External DB Service') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh 'kubectl apply -f k8s/ncp-db-service.yml'
                }
            }
        }

        stage('Run K8s Migration Job') {
            steps {
                dir('db-migration/jenkins-k8s-job') {
                    sh """
                        # DB 접속 정보 Secret 적용
                        kubectl apply -f k8s/db-secret.yml

                        # 기존 Job 삭제
                        kubectl delete job db-migration-job --ignore-not-found=true

                        # 이미지 태그 교체하여 Job 실행
                        sed "s|brunosong/db-migration:latest|${IMAGE_NAME}:${IMAGE_TAG}|g" \
                            k8s/migration-job.yml | kubectl apply -f -

                        # Job 완료 대기 (최대 5분)
                        kubectl wait --for=condition=complete job/db-migration-job --timeout=300s
                    """
                }
            }
        }

        stage('Verify Migration') {
            steps {
                sh 'kubectl logs job/db-migration-job'
            }
        }
    }

    post {
        success {
            echo 'DB 마이그레이션 성공!'
        }
        failure {
            echo 'DB 마이그레이션 실패. K8s Job 로그를 확인하세요.'
            sh 'kubectl logs job/db-migration-job || true'
        }
    }
}
