// Jira 호출 전용 잡 (잡 이름 예: 'jira-notify').
// 다른 파이프라인에서 build job: 'jira-notify' 로 트리거해서 호출.
//
// 책임:
//   1) Jira 코멘트 추가 (호출 잡 정보 + 사용자 메시지)
//   2) STATUS=SUCCESS + TRANSITION_ID 가 있으면 transition (예: Done)
//
// 분리 이점:
//   - Jira 자격증명을 이 잡 하나만 들고 있음 (보안 면에서 격리)
//   - 모든 호출이 Jenkins 빌드 히스토리에 남음 (감사/추적)
//   - Jira API 변경 시 이 잡 하나만 수정
//
// 잡 등록:
//   New Item → Pipeline → "Pipeline script from SCM" 로 이 파일 가리킴
//   Build Triggers 는 비워두기 (외부에서 build job: 으로만 트리거)
//
// 필요 Credentials (Secret text):
//   jira-base-url : 예) https://your-org.atlassian.net
//   jira-auth     : "<email>:<API_TOKEN>"

pipeline {
    agent any

    options {
        timestamps()
        // 같은 티켓에 동시 코멘트 방지 (필수는 아님)
        disableConcurrentBuilds()
    }

    parameters {
        string(
            name: 'ISSUE_KEY',
            defaultValue: '',
            description: '예) PROJ-123. 비우고 EXTRACT_FROM 만 넘겨도 됨.'
        )
        string(
            name: 'EXTRACT_FROM',
            defaultValue: '',
            description: 'ISSUE_KEY 가 비어있을 때 이 문자열에서 정규식으로 키 추출 (브랜치명/MR제목/커밋메시지 등).'
        )
        choice(
            name: 'STATUS',
            choices: ['SUCCESS', 'FAILURE'],
            description: '호출 잡의 결과.'
        )
        text(
            name: 'MESSAGE',
            defaultValue: '',
            description: '코멘트에 추가로 붙일 본문 (선택).'
        )
        string(
            name: 'CALLER_JOB',
            defaultValue: '',
            description: '호출 잡 이름 (보통 ${JOB_NAME}).'
        )
        string(
            name: 'CALLER_BUILD',
            defaultValue: '',
            description: '호출 빌드 번호 (보통 ${BUILD_NUMBER}).'
        )
        string(
            name: 'CALLER_URL',
            defaultValue: '',
            description: '호출 빌드 URL (보통 ${BUILD_URL}).'
        )
        string(
            name: 'TRANSITION_ID',
            defaultValue: '',
            description: 'transition ID (예: 31). 비우면 transition 안 함. STATUS=FAILURE 면 항상 무시.'
        )
    }

    environment {
        JIRA_BASE_URL = credentials('jira-base-url')
        JIRA_AUTH     = credentials('jira-auth')
    }

    stages {
        stage('Resolve issue key') {
            steps {
                script {
                    def key = params.ISSUE_KEY?.trim()
                    if (!key && params.EXTRACT_FROM?.trim()) {
                        def m = params.EXTRACT_FROM =~ /([A-Z][A-Z0-9]+-\d+)/
                        key = m ? m[0][1] : null
                    }
                    if (!key) {
                        echo 'Jira 키 못 찾음 — comment/transition 없이 정상 종료'
                        currentBuild.result = 'NOT_BUILT'
                        currentBuild.description = 'no jira key'
                        return
                    }
                    if (!(key ==~ /[A-Z][A-Z0-9]+-\d+/)) {
                        error "잘못된 ISSUE_KEY 형식: ${key}"
                    }
                    env.RESOLVED_KEY = key
                    currentBuild.description = "${key} / ${params.STATUS}"
                    echo "Resolved Jira key = ${key}"
                }
            }
        }

        stage('Add comment') {
            when { expression { env.RESOLVED_KEY } }
            steps {
                script {
                    def icon = params.STATUS == 'SUCCESS' ? '[OK]' : '[FAIL]'
                    def lines = [
                        "${icon} ${params.STATUS}",
                        "Job: ${params.CALLER_JOB ?: '-'} #${params.CALLER_BUILD ?: '-'}",
                        "Build URL: ${params.CALLER_URL ?: '-'}"
                    ]
                    if (params.MESSAGE?.trim()) {
                        lines += params.MESSAGE.split('\n').toList()
                    }
                    addJiraComment(env.RESOLVED_KEY, lines.join('\n'))
                }
            }
        }

        stage('Transition') {
            when {
                expression {
                    env.RESOLVED_KEY &&
                    params.STATUS == 'SUCCESS' &&
                    params.TRANSITION_ID?.trim()
                }
            }
            steps {
                script {
                    transitionJira(env.RESOLVED_KEY, params.TRANSITION_ID.trim())
                }
            }
        }
    }
}

// ─── Jira Cloud REST v3: 코멘트 추가 (ADF 포맷) ───
def addJiraComment(String issueKey, String text) {
    def body = groovy.json.JsonOutput.toJson([
        body: [
            type   : 'doc',
            version: 1,
            content: text.split('\n').collect { line ->
                [ type: 'paragraph', content: [[ type: 'text', text: line ]] ]
            }
        ]
    ])
    def resp = sh(
        returnStdout: true,
        script: """
            curl -sS -o /tmp/jira-comment.txt -w '%{http_code}' \\
                -u '${env.JIRA_AUTH}' \\
                -H 'Content-Type: application/json' \\
                -X POST '${env.JIRA_BASE_URL}/rest/api/3/issue/${issueKey}/comment' \\
                --data-binary @- <<'JSON'
${body}
JSON
        """
    ).trim()
    if (resp == '201') {
        echo "Jira ${issueKey} 코멘트 추가 완료"
    } else {
        def err = sh(script: 'cat /tmp/jira-comment.txt', returnStdout: true).trim()
        error "Jira 코멘트 실패 (HTTP ${resp}): ${err}"
    }
}

// ─── Jira Cloud REST v3: transition ───
def transitionJira(String issueKey, String transitionId) {
    def payload = groovy.json.JsonOutput.toJson([transition: [id: transitionId]])
    def resp = sh(
        returnStdout: true,
        script: """
            curl -sS -o /tmp/jira-trans.txt -w '%{http_code}' \\
                -u '${env.JIRA_AUTH}' \\
                -H 'Content-Type: application/json' \\
                -X POST '${env.JIRA_BASE_URL}/rest/api/3/issue/${issueKey}/transitions' \\
                --data-binary @- <<'JSON'
${payload}
JSON
        """
    ).trim()
    if (resp == '204') {
        echo "Jira ${issueKey} → transition(${transitionId}) 완료"
    } else {
        def err = sh(script: 'cat /tmp/jira-trans.txt', returnStdout: true).trim()
        error "Jira transition 실패 (HTTP ${resp}): ${err}"
    }
}
