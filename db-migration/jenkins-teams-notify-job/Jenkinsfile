// Teams 호출 전용 잡 (잡 이름 예: 'teams-notify').
// Jira 잡과 같은 패턴 — 다른 파이프라인이 build job: 'teams-notify' 로 호출.
//
// 엔드포인트: Microsoft Power Automate Workflows webhook (Adaptive Card 발송).
//   - 옛 Office 365 Connector "Incoming Webhook" 은 deprecated. 새로 만들지 말 것.
//
// Workflow 만들기 (1회):
//   1) Teams 채널 → ⋯ → Workflows
//   2) 템플릿 "Post to a channel when a webhook request is received" 선택
//   3) 채널 선택 → Create
//   4) 발급된 HTTP POST URL 복사 → Jenkins credential 'teams-webhook-url' 에 저장
//
// 필요 Credentials (Secret text):
//   teams-webhook-url : Workflow 가 발급한 URL

pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'STATUS',
            choices: ['SUCCESS', 'FAILURE', 'INFO'],
            description: '메시지 색상/아이콘 결정.'
        )
        string(
            name: 'TITLE',
            defaultValue: '',
            description: '카드 제목. 비우면 STATUS 로 자동 생성.'
        )
        text(
            name: 'MESSAGE',
            defaultValue: '',
            description: '카드 본문 (여러 줄 가능).'
        )
        string(
            name: 'CALLER_JOB',
            defaultValue: '',
            description: '호출 잡 이름 (보통 ${JOB_NAME}).'
        )
        string(
            name: 'CALLER_BUILD',
            defaultValue: '',
            description: '호출 빌드 번호 (보통 ${BUILD_NUMBER}).'
        )
        string(
            name: 'CALLER_URL',
            defaultValue: '',
            description: '호출 빌드 URL — 카드의 "Open Build" 버튼 링크.'
        )
        string(
            name: 'EXTRA_LINK_LABEL',
            defaultValue: '',
            description: '추가 액션 버튼 라벨 (선택).'
        )
        string(
            name: 'EXTRA_LINK_URL',
            defaultValue: '',
            description: '추가 액션 버튼 URL (선택).'
        )
    }

    environment {
        TEAMS_WEBHOOK_URL = credentials('teams-webhook-url')
    }

    stages {
        stage('Send') {
            steps {
                script {
                    def color = [
                        SUCCESS: 'good',
                        FAILURE: 'attention',
                        INFO   : 'accent'
                    ][params.STATUS] ?: 'default'

                    def title = params.TITLE?.trim() ?: "Build ${params.STATUS}"

                    def facts = []
                    if (params.CALLER_JOB?.trim()) {
                        facts << [title: 'Job', value: "${params.CALLER_JOB} #${params.CALLER_BUILD ?: '-'}"]
                    }
                    facts << [title: 'Status', value: params.STATUS]

                    def bodyBlocks = [
                        [
                            type   : 'TextBlock',
                            text   : title,
                            weight : 'Bolder',
                            size   : 'Medium',
                            color  : color,
                            wrap   : true
                        ],
                        [ type: 'FactSet', facts: facts ]
                    ]
                    if (params.MESSAGE?.trim()) {
                        bodyBlocks << [
                            type: 'TextBlock',
                            text: params.MESSAGE,
                            wrap: true
                        ]
                    }

                    def actions = []
                    if (params.CALLER_URL?.trim()) {
                        actions << [type: 'Action.OpenUrl', title: 'Open Build', url: params.CALLER_URL]
                    }
                    if (params.EXTRA_LINK_URL?.trim()) {
                        actions << [
                            type : 'Action.OpenUrl',
                            title: params.EXTRA_LINK_LABEL?.trim() ?: 'Open Link',
                            url  : params.EXTRA_LINK_URL
                        ]
                    }

                    def card = [
                        type       : 'message',
                        attachments: [[
                            contentType: 'application/vnd.microsoft.card.adaptive',
                            content    : [
                                type   : 'AdaptiveCard',
                                $schema: 'http://adaptivecards.io/schemas/adaptive-card.json',
                                version: '1.4',
                                body   : bodyBlocks,
                                actions: actions
                            ]
                        ]]
                    ]
                    def payload = groovy.json.JsonOutput.toJson(card)

                    def resp = sh(
                        returnStdout: true,
                        script: """
                            curl -sS -o /tmp/teams-resp.txt -w '%{http_code}' \\
                                -H 'Content-Type: application/json' \\
                                -X POST '${env.TEAMS_WEBHOOK_URL}' \\
                                --data-binary @- <<'JSON'
${payload}
JSON
                        """
                    ).trim()

                    if (resp == '200' || resp == '202') {
                        echo "Teams 알림 전송 완료 (HTTP ${resp})"
                    } else {
                        def err = sh(script: 'cat /tmp/teams-resp.txt', returnStdout: true).trim()
                        error "Teams 알림 실패 (HTTP ${resp}): ${err}"
                    }
                }
            }
        }
    }
}
